#include "main.h"
#include <stdio.h>
#include <stdlib.h>

/** 
* *create_array
* @size:variable
* @c:viriable
* Return: Always 0.
*/

char *create_array(unsigned int size, char c)
{
unsigned int a;

if (size <= 0)
return (NULL);

char *tbl;

tbl = malloc(sizeof(char) * size);

if (tbl == 0)
return (NULL);

for (a = 0; a <= size - 1; a++)
tbl[a] = c;

return (tbl);
}
