#include "main.h"
/**
* more_numbers - prints 10 time the numbers, from 0 to 14
*
* Return: Always 0.
*/
void more_numbers(void)

{
int rep = 0;
char c;
int b;

while (rep < 10)
{
for (c = '0'; c <= '9'; c++)
for (b = '0'; b <= '14'; b++)
if (c >= 10)
_putchar('1');
_putchar(b % 10);
}
_putchar ('\n');
}
