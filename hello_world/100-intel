#!/bin/bash

# Check if $CFILE is set
if [ -z "$CFILE" ]; then
    echo "Error: Environment variable \$CFILE is not set."
    exit 1
fi

# Check if the input C file exists
if [ ! -f "$CFILE" ]; then
    echo "Error: C file '$CFILE' not found."
    exit 1
fi

# Extract base name of the C file
BASENAME=$(basename "$CFILE" .c)

# Compile C file to assembly code (.s file)
gcc -S $CFILE -o $BASENAME.s -Wall -Werror -Wextra -pedantic -std=gnu89

# Check if compilation was successful
if [ $? -eq 0 ]; then
    echo "Assembly code generated successfully: $BASENAME.s"
else
    echo "Error: Compilation to assembly failed."
fi
